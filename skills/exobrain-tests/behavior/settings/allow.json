{
  "_comment": "Permission allowlist for the exobrain test harness 'action'/'build' profiles. Passed to `claude -p --settings`. Auto-approves safe file ops and the specific commands cases legitimately need; network and history-mutating commands are denied (deny wins over allow). Tune as cases evolve.",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(git:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(test:*)",
      "Bash(true)",
      "Bash(cd:*)",
      "Bash(scripts/connect-agent.sh:*)",
      "Bash(scripts/validate-exobrain.sh:*)",
      "Bash(scripts/skills-status.sh:*)",
      "Bash(scripts/skills-validate.sh:*)",
      "Bash(scripts/skills-promote.sh:*)",
      "Bash(scripts/create-worktree.sh:*)",
      "Bash(scripts/exobrain-healthcheck.sh:*)",
      "Bash(./scripts/connect-agent.sh:*)",
      "Bash(./scripts/validate-exobrain.sh:*)",
      "Bash(./scripts/create-worktree.sh:*)"
    ],
    "deny": [
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push:*)",
      "WebFetch",
      "WebSearch"
    ]
  }
}
