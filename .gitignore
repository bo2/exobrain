.DS_Store
.idea/
node_modules/
__pycache__/

# Agent markers and generated config — created locally by connect-agent.sh, never committed
.openclaw
.claude/*
!.claude/settings.json
.codex
.agents/

# Per-machine instance config and secrets
.exobrain.json
.env

# Private local scope — context that must never land in the repo (person/group
# scopes are committed like any other content).
/local/

# Generated / throwaway output and worktrees
tmp/
/src/
.worktrees/
.agent-worktrees/

# Agent orchestration / AFK runtime dirs
.agent-runs/
.agent-control/
